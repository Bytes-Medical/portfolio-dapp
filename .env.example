# Server-only. Never prefix with NEXT_PUBLIC_. Read only inside app/api/map/route.ts.
OPENAI_API_KEY=sk-...
OPENAI_MODEL_DEFAULT=gpt-4o-mini

# Server-only. Read only inside app/api/stt-token/route.ts (mints single-use voice tokens).
ELEVENLABS_API_KEY=sk_...

# No accounts or billing: the app is fully local (IndexedDB) and anonymous.
# If the app is ever monetised, it'll be a paid listing via the Play Store, not in-app.

# --- Mobile build only (Capacitor) ---
# The native app bundles a static UI with no server of its own, so it must call
# the hosted backend. Set this to the Render URL when running `npm run build:static`
# (it's baked into the bundle). Leave EMPTY for the web/Render build (same-origin).
# NEXT_PUBLIC_API_BASE_URL=https://byte-portfolio-api.onrender.com
